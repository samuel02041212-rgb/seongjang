# 이 파일을 web/.env 로 복사한 뒤 값 채우기.
#
# --- DB (PostgreSQL) — Neon ---
# ★ 로컬 가입 = 프로덕션 로그인까지 같게 쓰려면 DATABASE_URL 을 Vercel 과 동일하게.
#
# Neon 콘솔에서 두 가지 문자열을 복사하는 것을 권장합니다.
# - Pooled (-pooler): 앱 런타임(next dev / Vercel) → DATABASE_URL
# - Direct (비-pooler): prisma migrate / seed → DIRECT_URL (없으면 DATABASE_URL 폴백)
#
# Vercel Environment Variables 에는 최소 DATABASE_URL(Pooled) 필수.
# connect_timeout=15 는 compute 깨우기 대기에 도움이 됩니다.
#
# Neon에서 복사한 URL 끝에 &channel_binding=require 가 있으면 지우고 sslmode=require 를 유지하세요.
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require&connect_timeout=15"
#
# 1) https://neon.tech
# 2) web/ 에서: npx prisma migrate deploy (오류 시 DIRECT_URL 을 Direct 문자열로 채운 뒤 재시도)
# 3) 선택: npm run db:seed
#
# --- 로컬 Docker 대안 (선택) ---
# 저장소 루트에서 docker compose up -d 후:
# DATABASE_URL="postgresql://seongjang:seongjang_dev@localhost:5432/seongjang"
# (이 경우 DIRECT_URL 은 비워도 됩니다.)
#
# openssl rand -base64 32 — 비어 있으면 로그인 JWT가 불안정할 수 있음
AUTH_SECRET=""
# 로컬: http://localhost:3000 | 배포 후: https://실제도메인 (슬래시 없이)
AUTH_URL="http://localhost:3000"

# 팀 테스트: 운영에서도 가입 즉시 로그인 허용이면 1
# REGISTRATION_AUTO_APPROVE=1

# (거의 쓰지 않음) 로컬에서만 시드 계정 우회. Vercel에서는 무시됨.
# AUTH_DEV_BYPASS=1
