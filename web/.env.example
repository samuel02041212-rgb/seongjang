# 이 파일을 web/.env 로 복사한 뒤 값 채우기.
#
# --- DB (PostgreSQL) — 추천: 클라우드 Neon ---
# 이 스택은 MongoDB Atlas가 아니라 PostgreSQL입니다. Atlas URL은 쓸 수 없습니다.
#
# ★ 로컬 가입 = 프로덕션 로그인까지 같게 쓰려면:
#   web/.env 의 DATABASE_URL 을 Vercel Environment Variables 와 같은 Neon URL 로 맞추세요.
#
# ★ Vercel 에 넣은 URL 은 보통 Connection pooling(-pooler) 호스트입니다. 그대로 로컬에도 사용 가능합니다.
#   prisma migrate deploy 만 로컬에서 안 되면 Neon 콘솔의 Direct(비-pooler) 문자열로 한 번 실행하세요.
#
# 1) https://neon.tech 에서 프로젝트 생성 → Connection string 복사
# 2) 아래 DATABASE_URL 에 그대로 붙여넣기 (끝에 ?sslmode=require 있으면 유지)
# 3) web/ 에서: npx prisma migrate deploy
# 4) 선택: npm run db:seed  (관리자 a/a, 개발계정 dev@seongjang.local / devpassword)
# 자세한 단계: 저장소 루트의 따라하기-클라우드DB-Neon.md
#
# --- 로컬 Docker 대안 (선택) ---
# 저장소 루트에서 docker compose up -d 후:
# DATABASE_URL="postgresql://seongjang:seongjang_dev@localhost:5432/seongjang"
#
# Neon에서 복사한 URL 끝에 &channel_binding=require 가 있으면 연결이 안 될 수 있습니다.
# 그럴 때는 ?sslmode=require 만 남기고 &channel_binding=require 는 지워 보세요.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# openssl rand -base64 32 — 비어 있으면 로그인 JWT가 불안정할 수 있음
AUTH_SECRET=""
# 로컬: http://localhost:3000 | 배포 후: https://실제도메인 (슬래시 없이)
AUTH_URL="http://localhost:3000"

# 팀 테스트: 운영에서도 가입 즉시 로그인 가능하게 하려면 1 (관리자 승인 미사용)
# 승인 플로우만 쓰려면 비우거나 0
# REGISTRATION_AUTO_APPROVE=1

# (거의 쓰지 않음) 로컬에서만 시드 계정 dev@seongjang.local 로 세션 우회. Vercel에서는 무시됨.
# AUTH_DEV_BYPASS=1
