# Local dev using the SAME Neon DB as production:
# 1) Vercel → Project → Settings → Environment Variables
# 2) Copy DATABASE_URL (pooled) and paste below.
# 3) Copy DIRECT_URL if you use Neon "direct" for prisma migrate (or omit).
# 4) Copy AUTH_SECRET from Vercel into AUTH_SECRET here (same secret = same signing; keep AUTH_URL for local only).
# 5) AUTH_URL must stay http://localhost:3000 for local next dev.

DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL=""
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
REGISTRATION_AUTO_APPROVE=
AUTH_DEV_BYPASS=
